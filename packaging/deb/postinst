#!/usr/bin/env bash
# xdr-agent - Modular XDR endpoint security agent for Linux
# Copyright (C) 2026  Diego A. Guillen-Rosaperez
# SPDX-License-Identifier: AGPL-3.0
set -e

if [ ! -f /etc/xdr-agent/config.json ] && [ -f /etc/xdr-agent/config.default.json ]; then
  cp -f /etc/xdr-agent/config.default.json /etc/xdr-agent/config.json
  chmod 0644 /etc/xdr-agent/config.json
fi

if [ -x /usr/bin/xdr-agent ]; then
  mkdir -p /usr/share/bash-completion/completions || true
  /usr/bin/xdr-agent completion bash >/usr/share/bash-completion/completions/xdr-agent || true
  chmod 0644 /usr/share/bash-completion/completions/xdr-agent || true
fi

if command -v systemctl >/dev/null 2>&1; then
  systemctl daemon-reload || true
  systemctl preset xdr-agent.service || true

  # $2 is the previously-installed version (set by dpkg on upgrade, empty on
  # fresh install).  On upgrade we must re-enable and start the service so the
  # new binary takes over.  On a fresh install the service stays disabled
  # (per the systemd preset) until the administrator explicitly enrolls.
  if [ -n "$2" ]; then
    systemctl enable xdr-agent.service || true
    systemctl start xdr-agent.service  || true
  fi
fi

exit 0
