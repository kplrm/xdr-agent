Name:           xdr-agent
Version:        @VERSION@
Release:        1
Summary:        Lightweight XDR agent (identity and enrollment)
License:        AGPL-3.0
URL:            https://example.com/xdr-agent
BuildArch:      @RPM_ARCH@
Requires(post): systemd
Requires(preun): systemd
Requires(postun): systemd

%description
A minimal host agent that establishes identity and enrolls into a control plane.

%prep

%build

%install
mkdir -p %{buildroot}/usr/bin
mkdir -p %{buildroot}/etc/xdr-agent
mkdir -p %{buildroot}/usr/lib/systemd/system
mkdir -p %{buildroot}/var/lib/xdr-agent

install -m 0755 %{_sourcedir}/xdr-agent %{buildroot}/usr/bin/xdr-agent
install -m 0644 %{_sourcedir}/config.json %{buildroot}/etc/xdr-agent/config.default.json
install -m 0644 %{_sourcedir}/xdr-agent.service %{buildroot}/usr/lib/systemd/system/xdr-agent.service

mkdir -p %{buildroot}/usr/share/doc/xdr-agent
install -m 0644 %{_sourcedir}/LICENSE %{buildroot}/usr/share/doc/xdr-agent/LICENSE
install -m 0644 %{_sourcedir}/AUTHORS %{buildroot}/usr/share/doc/xdr-agent/AUTHORS

%files
%license /usr/share/doc/xdr-agent/LICENSE
%doc /usr/share/doc/xdr-agent/AUTHORS
/usr/bin/xdr-agent
/etc/xdr-agent/config.default.json
/usr/lib/systemd/system/xdr-agent.service
%dir /etc/xdr-agent
%dir /var/lib/xdr-agent

%post
# Install default config if none exists (never overwrite user edits)
if [ ! -f /etc/xdr-agent/config.json ] && [ -f /etc/xdr-agent/config.default.json ]; then
  cp -f /etc/xdr-agent/config.default.json /etc/xdr-agent/config.json
  chmod 0644 /etc/xdr-agent/config.json
fi
if [ -x /usr/bin/systemctl ]; then
  /usr/bin/systemctl daemon-reload || true
  /usr/bin/systemctl enable xdr-agent.service || true
  /usr/bin/systemctl restart xdr-agent.service || true
fi

%preun
if [ "$1" -eq 0 ] && [ -x /usr/bin/systemctl ]; then
  /usr/bin/systemctl stop xdr-agent.service || true
  /usr/bin/systemctl disable xdr-agent.service || true
fi

%postun
if [ -x /usr/bin/systemctl ]; then
  /usr/bin/systemctl daemon-reload || true
fi
